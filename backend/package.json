{
  "name": "sicerdas-backend",
  "version": "1.0.0",
  "description": "SiCerdas backend code",
  "keywords": [
    "api",
    "fastify",
    "server",
    "template",
    "typescript"
  ],
  "homepage": "https://sicerdas.com",
  "license": "",
  "author": "Toto Sugito",
  "repository": {
    "type": "git",
    "url": ""
  },
  "type": "module",
  "scripts": {
    "start": "bun run build && cross-env NODE_ENV=production bun dist/server.js",
    "dev": "cross-env NODE_ENV=development bun --watch src/server.ts | pino-pretty --colorize",
    "build": "rimraf dist && tsc -p tsconfig.build.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:drop": "drizzle-kit drop",
    "db:push_dev": "cross-env NODE_ENV=development drizzle-kit push",
    "db:init_all": "cross-env NODE_ENV=development bun src/scripts/init/run-inital-data.ts --trace-warnings",
    "db:schedule": "cross-env NODE_ENV=development bun src/scripts/schedule/daily/daily.ts --trace-warnings",
    "db:init_user": "cross-env NODE_ENV=development bun src/scripts/init/jobs/init-user.ts --trace-warnings"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1089.0",
    "@blocknote/core": "^0.51.4",
    "@blocknote/server-util": "^0.51.4",
    "@fastify/autoload": "^6.4.0",
    "@fastify/compress": "^9.1.0",
    "@fastify/cookie": "^11.1.2",
    "@fastify/cors": "^11.3.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/multipart": "^10.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/static": "^10.1.0",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@fastify/under-pressure": "^9.1.0",
    "@getbrevo/brevo": "^6.0.2",
    "@scalar/fastify-api-reference": "^1.62.9",
    "@sinclair/typebox": "^0.34.52",
    "axios": "^1.18.1",
    "better-auth": "^1.6.23",
    "close-with-grace": "^2.5.0",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "env-schema": "^7.0.0",
    "fastify": "^5.10.0",
    "fastify-i18n": "^3.0.0",
    "fastify-plugin": "^6.0.0",
    "mathjs": "^15.2.0",
    "pg": "^8.22.0",
    "pino-roll": "^4.0.0",
    "sharp": "^0.35.3",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "c8": "^12.0.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=22.20.0",
    "bun": ">=1.0.0"
  },
  "packageManager": "bun@1.3.14"
}